Rule 5     param_list -> param_list_nonempty
Rule 6     param_list -> empty
Rule 7     param_list_nonempty -> param_list_nonempty COMMA IDENTIFIER
Rule 8     param_list_nonempty -> IDENTIFIER
Rule 9     main_block -> block
Rule 10    block -> BEGIN statement_list END
Rule 11    statement_list -> statement_list statement SEMICOLON
Rule 12    statement_list -> statement SEMICOLON
Rule 13    statement -> assignment_stmt
Rule 14    statement -> array_decl
Rule 15    statement -> if_stmt
Rule 16    statement -> while_stmt
Rule 17    statement -> for_stmt
Rule 18    statement -> read_stmt
Rule 19    statement -> write_stmt
Rule 20    statement -> return_stmt
