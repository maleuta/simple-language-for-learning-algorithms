Rule 22    statement -> block
Rule 23    statement -> empty
Rule 24    empty -> <empty>
Rule 25    array_decl -> ARRAY IDENTIFIER LBRACKET expression RBRACKET
Rule 26    assignment_stmt -> IDENTIFIER ASSIGN expression
Rule 27    assignment_stmt -> IDENTIFIER LBRACKET expression RBRACKET ASSIGN expression
Rule 28    if_stmt -> IF expression THEN statement
Rule 29    if_stmt -> IF expression THEN statement ELSE statement
Rule 30    while_stmt -> WHILE expression DO statement
Rule 31    for_stmt -> FOR IDENTIFIER ASSIGN expression TO expression DO statement
Rule 32    read_stmt -> READ LPAREN IDENTIFIER RPAREN
Rule 33    read_stmt -> READ LPAREN IDENTIFIER LBRACKET expression RBRACKET RPAREN
Rule 34    write_stmt -> WRITE LPAREN expression RPAREN
Rule 35    return_stmt -> RETURN expression
Rule 36    function_call_stmt -> IDENTIFIER LPAREN arg_list RPAREN
Rule 37    arg_list -> arg_list_nonempty
Rule 38    arg_list -> empty
Rule 39    arg_list_nonempty -> arg_list_nonempty COMMA expression
Rule 40    arg_list_nonempty -> expression
Rule 41    expression -> logical_expression
Rule 42    logical_expression -> logical_expression OR logical_and_expr
Rule 43    logical_expression -> logical_and_expr
Rule 44    logical_and_expr -> logical_and_expr AND rel_expr
Rule 45    logical_and_expr -> rel_expr
Rule 46    rel_expr -> math_expr RELOP math_expr
Rule 47    rel_expr -> math_expr
Rule 48    math_expr -> math_expr ADD_OP term
Rule 49    math_expr -> term
Rule 50    term -> term MULT_OP factor
Rule 51    term -> factor
Rule 52    factor -> IDENTIFIER
Rule 53    factor -> IDENTIFIER LBRACKET expression RBRACKET
Rule 54    factor -> IDENTIFIER LPAREN arg_list RPAREN
Rule 55    factor -> INTEGER
Rule 56    factor -> FLOAT
Rule 57    factor -> STR
Rule 58    factor -> TRUE
Rule 59    factor -> FALSE
Rule 60    factor -> LPAREN expression RPAREN
Rule 61    factor -> NOT factor
Rule 62    factor -> ADD_OP factor

